{
  "buildCommand": "cd frontend && npm install && npm run build && cd .. && npm install",
  "functions": {
    "server.js": {
      "runtime": "@vercel/node@3.2.10"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}